MENDARR_HOST=0.0.0.0
MENDARR_PORT=8095
# Required for real use. Replace both secret values before exposing the app.
MENDARR_SECRET_KEY=change-me-to-a-long-random-secret
MENDARR_ENCRYPTION_KEY=change-me-to-a-second-long-random-secret
MENDARR_ADMIN_USERNAME=admin
MENDARR_ADMIN_PASSWORD=change-me-to-a-strong-password
MENDARR_DATA_DIR=./data
MENDARR_DATABASE_URL=sqlite+aiosqlite:///./data/mendarr.db
MENDARR_FFPROBE_PATH=ffprobe
MENDARR_SCAN_PRECOUNT_ENABLED=false
MENDARR_LOG_LEVEL=INFO
MENDARR_TIMEZONE=UTC
MENDARR_SCAN_PATH_HINTS=
MENDARR_PATH_MAPPINGS=
MENDARR_TRUST_PROXY_HEADERS=false
MENDARR_APP_VERSION=1.0.1
MENDARR_PUBLIC_REPO=Necrul/Mendarr
MENDARR_UPDATE_CHECK_ENABLED=true
MENDARR_UPDATE_CHECK_INTERVAL_HOURS=12
